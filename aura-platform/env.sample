# AURA Platform Configuration
# OpenAI x NxtWave Buildathon
# 
# Copy this file to .env and add your API keys:
# cp env.sample .env

NODE_ENV=development
PORT=3000

# Azure OpenAI Configuration (Primary - for buildathon)
# Get your key from Azure Portal
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_CHATGPT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_CHATGPT_MODEL=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# OpenAI API Key (Alternative/Fallback)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Fi MCP Service Configuration
# For local development: use localhost:8080
# For production (Azure): use the Azure App Service URL
FI_MCP_URL=https://fi-mcp-server-fnfkgsazeudpdcd2.centralindia-01.azurewebsites.net

# LangSmith Configuration (Optional - for observability)
# Get your key from: https://smith.langchain.com
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=aura-finance

# Silent mode for fallbacks (set to true to hide fallback warnings)
SILENT_FALLBACK=true

# MongoDB Configuration
# For local: mongodb://localhost:27017/aura_finance
# For production: Use MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017/aura_finance

# Market Data APIs (Optional - enhances real-time data)
TRUEDATA_API_KEY=
POLYGON_API_KEY=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
